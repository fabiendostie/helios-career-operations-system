<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ candidate_name }} - Resume</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 11pt;
            line-height: 1.4;
            color: #000000;
            max-width: 8.5in;
            margin: 0 auto;
            padding: 0.75in;
        }
        h1 {
            font-size: 16pt;
            font-weight: bold;
            text-align: center;
            margin-bottom: 6pt;
        }
        h2 {
            font-size: 14pt;
            font-weight: bold;
            border-bottom: 1pt solid #000000;
            padding-bottom: 4pt;
            margin: 16pt 0 8pt 0;
        }
        .contact-info {
            text-align: center;
            font-size: 10pt;
            margin-bottom: 12pt;
        }
        .summary {
            margin: 8pt 0;
            text-align: justify;
        }
        .skills {
            font-size: 10pt;
            margin: 8pt 0;
        }
        .job-entry {
            margin-bottom: 16pt;
        }
        .job-header {
            margin-bottom: 4pt;
        }
        .job-title {
            font-weight: bold;
            font-size: 12pt;
        }
        .company {
            font-size: 11pt;
        }
        .duration {
            font-size: 10pt;
            float: right;
            color: #333333;
        }
        .accomplishments {
            margin: 6pt 0 6pt 20pt;
            padding: 0;
        }
        .accomplishments li {
            margin-bottom: 3pt;
            font-size: 11pt;
            line-height: 1.3;
        }
        .skills-used {
            font-size: 9pt;
            color: #666666;
            margin-top: 4pt;
            font-style: italic;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <h1>{{ candidate_name }}</h1>
    <div class="contact-info">
        {{ email }}
        {% if phone %} | {{ phone }}{% endif %}
        {% if location %} | {{ location }}{% endif %}
    </div>
    
    <!-- Summary -->
    {% if summary %}
    <div class="summary">{{ summary }}</div>
    {% endif %}
    
    <!-- Core Skills -->
    {% if core_skills %}
    <div class="skills">
        <strong>Core Competencies:</strong> {{ core_skills | join(' • ') }}
    </div>
    {% endif %}
    
    <!-- Professional Experience -->
    {% if work_experience %}
    <h2>Professional Experience</h2>
    {% for job in work_experience %}
    <div class="job-entry">
        <div class="job-header">
            <span class="job-title">{{ job.role_title }}</span>
            <span class="company"> - {{ job.company_name }}</span>
            <span class="duration">{{ job.duration }}</span>
        </div>
        {% if job.accomplishments %}
        <ul class="accomplishments">
            {% for accomplishment in job.accomplishments %}
            <li>{{ accomplishment }}</li>
            {% endfor %}
        </ul>
        {% endif %}
        {% if job.skills_used %}
        <div class="skills-used">
            <em>Technologies:</em> {{ job.skills_used | join(', ') }}
        </div>
        {% endif %}
    </div>
    {% endfor %}
    {% endif %}
    
    <!-- Education -->
    {% if education %}
    <h2>Education</h2>
    {% for edu in education %}
    <div class="education-entry">
        <strong>{{ edu.degree }}</strong> - {{ edu.institution }}{% if edu.year %} ({{ edu.year }}){% endif %}
    </div>
    {% endfor %}
    {% endif %}
</body>
</html>