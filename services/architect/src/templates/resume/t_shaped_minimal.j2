<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ candidate_name }} - Resume</title>
    <link rel="stylesheet" href="../styles/minimal.css">
</head>
<body>
    <!-- T-Shaped Top Bar: Ultra-minimal Impact Summary -->
    <section class="impact-summary">
        <h1>{{ candidate_name }}</h1>

        <div class="contact-info">
            {{ email }}{% if phone %} | {{ phone }}{% endif %}{% if location %} | {{ location }}{% endif %}
        </div>

        <!-- Simplified Impact Summary for maximum ATS parsability -->
        <p class="summary">
            {{ adjective }} {{ target_role_title }} with {{ years_experience }} years of experience in {{ core_competency_1 }}, {{ core_competency_2 }}, and {{ core_technology }}. {{ top_quantified_achievement }} through {{ skill_area }} expertise.
        </p>

        <!-- Simple skills list -->
        <div class="core-skills">
            <strong>Skills:</strong> {{ core_skills[:8] | join_with_comma }}
        </div>
    </section>

    <!-- T-Shaped Vertical Bar: Minimal Experience Log -->
    <section class="experience-log">
        <h2>Professional Experience</h2>

        {% for job in work_experience %}
        <div class="job-entry">
            <h3>{{ job.role_title | default('Professional') }}</h3>
            <p><strong>{{ job.company_name | default('Company') }}</strong> | {{ job.start_date | format_duration(job.end_date) }}</p>

            <ul class="accomplishments">
                {% for accomplishment in job.accomplishments %}
                <li>{{ accomplishment }}</li>
                {% endfor %}
            </ul>

            {% if job.skills_used %}
            <p><em>Technologies:</em> {{ job.skills_used | join_with_comma }}</p>
            {% endif %}
        </div>
        {% endfor %}
    </section>

    <!-- Minimal Additional Sections -->
    {% if education %}
    <section class="education">
        <h2>Education</h2>
        {% for edu in education %}
        <p><strong>{{ edu.degree | default('Degree') }}</strong>{% if edu.institution %} - {{ edu.institution }}{% endif %}{% if edu.year %} ({{ edu.year }}){% endif %}</p>
        {% endfor %}
    </section>
    {% endif %}

    {% if technical_skills %}
    <section class="technical-skills">
        <h2>Technical Skills</h2>
        {% for category, skills in technical_skills.items() %}
        <p><strong>{{ category | capitalize_first }}:</strong> {{ skills | join_with_comma }}</p>
        {% endfor %}
    </section>
    {% endif %}

    {% if career_data.certifications %}
    <section class="certifications">
        <h2>Certifications</h2>
        {% for cert in career_data.certifications %}
        <p><strong>{{ cert.name }}</strong>{% if cert.issuer %} - {{ cert.issuer }}{% endif %}{% if cert.year %} ({{ cert.year }}){% endif %}</p>
        {% endfor %}
    </section>
    {% endif %}
</body>
</html>
