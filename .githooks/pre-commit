#!/bin/bash
#
# Enhanced Pre-Commit Hook for BMAD Automation
# Automatically updates progress tracking, generates documentation, and ensures quality
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Project root directory
PROJECT_ROOT="$(git rev-parse --show-toplevel)"

# Function to log with timestamp
log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] PRE-COMMIT: $1" >> "$PROJECT_ROOT/.git/hooks.log"
}

# Function to check if Python is available
check_python() {
    # Check Windows Python locations first
    if [ -f "/c/Users/fabie/AppData/Local/Programs/Python/Python313/python.exe" ]; then
        echo "/c/Users/fabie/AppData/Local/Programs/Python/Python313/python.exe"
    elif command -v python3 &> /dev/null; then
        echo "python3"
    elif command -v python &> /dev/null; then
        echo "python"
    elif [ -f "/c/Python313/python.exe" ]; then
        echo "/c/Python313/python.exe"
    else
        return 1
    fi
}

echo -e "${BLUE}🤖 BMAD Automated Pre-Commit Pipeline${NC}"
echo -e "${BLUE}======================================${NC}"

log_message "Starting BMAD pre-commit automation pipeline"

# Get Python command
PYTHON_CMD=$(check_python)
if [ $? -ne 0 ]; then
    echo -e "${RED}❌ Python not found. Required for automation.${NC}"
    log_message "Python not found, aborting automation"
    exit 1
fi

cd "$PROJECT_ROOT"

# Step 1: Update BMAD progress tracking
echo -e "${BLUE}📊 Step 1: Updating BMAD progress tracking...${NC}"
if [ -f "scripts/automation/auto_progress_tracker.py" ]; then
    if $PYTHON_CMD scripts/automation/auto_progress_tracker.py --hook; then
        echo -e "${GREEN}✅ Progress tracking updated${NC}"
        log_message "Progress tracking updated successfully"
    else
        echo -e "${YELLOW}⚠️ Progress tracking failed, continuing...${NC}"
        log_message "Progress tracking failed but continuing"
    fi
else
    echo -e "${YELLOW}⚠️ Progress tracker not found, skipping...${NC}"
fi

# Step 2: Generate documentation
echo -e "${BLUE}📝 Step 2: Generating BMAD-integrated documentation...${NC}"
if [ -f "scripts/generate_docs.py" ]; then
    if $PYTHON_CMD scripts/generate_docs.py; then
        echo -e "${GREEN}✅ Documentation generated${NC}"
        log_message "Documentation generated successfully"

        # Stage generated documentation
        git add docs/api/ 2>/dev/null || true
    else
        echo -e "${YELLOW}⚠️ Documentation generation failed, continuing...${NC}"
        log_message "Documentation generation failed but continuing"
    fi
else
    echo -e "${YELLOW}⚠️ Documentation generator not found, skipping...${NC}"
fi

# Step 3: Generate README and changelog
echo -e "${BLUE}📋 Step 3: Updating README and changelog...${NC}"
if [ -f "scripts/automation/auto_documentation_generator.py" ]; then
    if $PYTHON_CMD scripts/automation/auto_documentation_generator.py; then
        echo -e "${GREEN}✅ README and changelog updated${NC}"
        log_message "README and changelog updated successfully"
    else
        echo -e "${YELLOW}⚠️ README/changelog update failed, continuing...${NC}"
        log_message "README/changelog update failed but continuing"
    fi
else
    echo -e "${YELLOW}⚠️ Auto documentation generator not found, skipping...${NC}"
fi

# Step 4: Run original pre-commit hooks (code quality)
echo -e "${BLUE}🔍 Step 4: Running code quality checks...${NC}"
if [ -f ".pre-commit-config.yaml" ] && command -v pre-commit &> /dev/null; then
    # Get the original pre-commit hook path
    ORIGINAL_HOOK="$PROJECT_ROOT/.git/hooks/pre-commit.pre-commit"
    if [ -f "$ORIGINAL_HOOK" ]; then
        echo -e "${BLUE}   Running pre-commit quality checks...${NC}"
        if "$ORIGINAL_HOOK"; then
            echo -e "${GREEN}✅ Code quality checks passed${NC}"
            log_message "Code quality checks passed"
        else
            echo -e "${RED}❌ Code quality checks failed${NC}"
            log_message "Code quality checks failed"
            exit 1
        fi
    else
        # Fallback: run pre-commit directly
        if pre-commit run --hook-stage=pre-commit; then
            echo -e "${GREEN}✅ Code quality checks passed${NC}"
            log_message "Code quality checks passed"
        else
            echo -e "${RED}❌ Code quality checks failed${NC}"
            log_message "Code quality checks failed"
            exit 1
        fi
    fi
else
    echo -e "${YELLOW}⚠️ Pre-commit not configured, skipping quality checks...${NC}"
fi

# Step 5: Verify BMAD methodology compliance
echo -e "${BLUE}📚 Step 5: Verifying BMAD methodology compliance...${NC}"
BMAD_COMPLIANT=true

# Check if required BMAD files exist and are updated
if [ ! -f "bmad-progress/progress-log.json" ]; then
    echo -e "${YELLOW}⚠️ BMAD progress log missing${NC}"
    BMAD_COMPLIANT=false
fi

if [ ! -f "docs/mvp-backlog-report.md" ]; then
    echo -e "${YELLOW}⚠️ MVP backlog report missing${NC}"
    BMAD_COMPLIANT=false
fi

# Check if epics are updated when services change
CHANGED_SERVICES=$(git diff --cached --name-only | grep "^services/" | cut -d'/' -f2 | sort -u)
if [ ! -z "$CHANGED_SERVICES" ]; then
    echo -e "${BLUE}   Detected changes in services: $(echo $CHANGED_SERVICES | tr '\n' ' ')${NC}"

    # Check if epic documentation is also updated
    EPIC_CHANGES=$(git diff --cached --name-only | grep -E "(epic|story|backlog)" | wc -l)
    if [ "$EPIC_CHANGES" -eq 0 ]; then
        echo -e "${YELLOW}⚠️ Service changes detected but no epic/story updates found${NC}"
        echo -e "${YELLOW}   Consider updating relevant epic documentation${NC}"
    fi
fi

if [ "$BMAD_COMPLIANT" = true ]; then
    echo -e "${GREEN}✅ BMAD methodology compliance verified${NC}"
    log_message "BMAD methodology compliance verified"
else
    echo -e "${YELLOW}⚠️ BMAD compliance issues detected but allowing commit${NC}"
    log_message "BMAD compliance issues detected but allowing commit"
fi

# Step 6: Final summary
echo -e "${BLUE}📋 Step 6: Pre-commit automation summary${NC}"
STAGED_FILES=$(git diff --cached --name-only | wc -l)
echo -e "${GREEN}✅ BMAD automated pre-commit pipeline completed${NC}"
echo -e "${BLUE}   Staged files: $STAGED_FILES${NC}"
echo -e "${BLUE}   Ready for commit with conventional commit message${NC}"

log_message "BMAD automated pre-commit pipeline completed successfully"

exit 0